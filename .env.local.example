# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it's already in .gitignore.

# ─── App ─────────────────────────────────────────────────────────────────────
# Canonical production URL — used server-side to build absolute links (invite
# emails, magic links, Dodo checkout return URLs) so they never fall back to a
# proxy/preview domain.
NEXT_PUBLIC_APP_URL=https://facultify.in

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API

# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-side only, NEVER commit or expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Facultify <no-reply@facultify.in>

# ─── Dodo Payments ────────────────────────────────────────────────────────────
# Dashboard → Developer → API Keys / Webhooks
# https://docs.dodopayments.com
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Webhook signing key from Dashboard → Developer → Webhooks
DODO_PAYMENTS_WEBHOOK_KEY=

# Product IDs — create one Product per tier x billing cycle in the Dodo
# dashboard (Starter/Institution/Campus, each with a monthly and an annual
# recurring price), then paste their product IDs here.
DODO_PRICE_STARTER_MONTHLY=
DODO_PRICE_STARTER_ANNUAL=
DODO_PRICE_INSTITUTION_MONTHLY=
DODO_PRICE_INSTITUTION_ANNUAL=
DODO_PRICE_CAMPUS_MONTHLY=
DODO_PRICE_CAMPUS_ANNUAL=

# ─── AI Generation (for the Edge Function) ───────────────────────────────────
# Set this in Supabase Dashboard → Edge Functions → Secrets, not here
# OPENAI_API_KEY=sk-...

# Playwright e2e fixtures (scripts/seed-e2e.mjs)
E2E_TEACHER_EMAIL=teacher.e2e@facultify.test
E2E_STUDENT_EMAIL=student.e2e@facultify.test
E2E_PASSWORD=
